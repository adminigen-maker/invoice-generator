# Supabase (get these from your Supabase project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role — server-side only, NEVER expose to the browser.
# Used for admin operations that bypass RLS (e.g. seeding, system tasks).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Company defaults (used across printed documents)
NEXT_PUBLIC_COMPANY_NAME="Your Company LLC"
NEXT_PUBLIC_COMPANY_CURRENCY=AED
NEXT_PUBLIC_COMPANY_TAX_RATE=5
NEXT_PUBLIC_COMPANY_TAX_LABEL=VAT
